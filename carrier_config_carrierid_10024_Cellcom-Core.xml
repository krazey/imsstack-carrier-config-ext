<carrier_config>
    <!-- Please always keep this config on the first line. -->
    <!-- Specifies a list of parent carrier ids from which to inherit configuration values. -->
    <int-array name="ims.parent_carrier_ids_int_array" num="1">
        <item value="1802"/>
    </int-array>

    <!-- Ims General -->
    <boolean name="ims.allow_sip_p_access_network_info_header_in_initial_register_bool" value="true"/>
    <int name="ims.registration_contact_user_info_part_int" value="1"/>

    <!-- Aos -->
    <int name="ims.isim_index_for_impu_int" value="0"/>
    <int-array name="ims.reg_permanent_err_max_cnt_int_array" num="1">
        <item value="2"/>
    </int-array>
    <int-array name="ims.registration_permanent_error_code_int_array" num="4">
        <item value="400"/>
        <item value="402"/>
        <item value="421"/>
        <item value="484"/>
    </int-array>
    <int-array name="ims.rereg_retry_err_code_for_init_reg_with_same_pcscf_int_array" num="1">
        <item value="481"/>
    </int-array>
    <!-- KEY_EXTRA_REG_ERR_BUNDLE -->
    <pbundle_as_map name="ims.extra_reg_err_bundle">
        <int name="ims.extra_reg_err_policy_int" value="4"/>
        <int-array name="ims.extra_reg_err_code_for_update_int_array" num="2">
            <item value="403"/>
            <item value="404"/>
        </int-array>
        <int-array name="ims.extra_reg_err_code_int_array" num="2">
            <item value="403"/>
            <item value="404"/>
        </int-array>
        <int-array name="ims.extra_reg_err_wait_time_sec_int_array" num="1">
            <item value="30"/>
        </int-array>
    </pbundle_as_map>
    <!-- KEY_NOTIFY_TERMINATED_FOR_INIT_REG_BUNDLE -->
    <pbundle_as_map name="ims.notify_terminated_for_init_reg_bundle">
        <int name="ims.notify_terminated_for_init_reg_with_wait_time_int" value="60"/>
        <int-array name="ims.notify_terminated_for_init_reg_used_event_int_array" num="4">
            <item value="1"/>
            <item value="2"/>
            <item value="3"/>
            <item value="5"/>
        </int-array>
        <int-array name="ims.notify_terminated_for_init_reg_used_event_with_wait_time_int_array" num="2">
            <item value="2"/>
            <item value="5"/>
        </int-array>
    </pbundle_as_map>
</carrier_config>
