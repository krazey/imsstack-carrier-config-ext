        </pbundle>
    </pbundle>
    <pbundle name="imsvoice.amrwb_payload_description_bundle">
        <pbundle name="97">
            <int-array name="imsvoice.amr_codec_attribute_modeset_int_array" num="3">
                <item value="0"/>
                <item value="1"/>
                <item value="2"/>
            </int-array>
            <int name="imsvoice.amr_codec_attribute_payload_format_int" value="0"/>
            <int name="imsvoice.codec_attribute_mode_change_capability_int" value="2"/>
