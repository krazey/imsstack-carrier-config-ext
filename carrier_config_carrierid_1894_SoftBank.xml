<carrier_config>
    <!-- Carrier configurations -->
    <!-- Ims General -->
    <string name="ims.ims_user_agent_string">#IMEISV#_suppfork</string>

    <!-- Aos -->
    <boolean name="ims.use_tcp_transport_for_register_bool" value="true"/>
    <int name="ims.isim_index_for_impu_int" value="0"/>
    <int name="ims.registration_preferred_accesstype_feature_tag_int" value="0"/>
    <!-- KEY_SUB_ERR_CODE_FOR_INIT_REG_BUNDLE -->
    <pbundle name="ims.sub_err_code_for_init_reg_bundle">
        <int name="ims.sub_err_code_for_init_reg_with_retry_max_cnt_int" value="2"/>
        <int-array name="ims.sub_err_code_for_init_reg_int_array" num="3">
            <item value="500"/>
            <item value="503"/>
            <item value="600"/>
        </int-array>
    </pbundle>

    <!-- Assets: non-carrier configurations -->
    <!-- Ims General -->
    <boolean name="session_timer_update_required_in_session_update_by_reinvite_bool" value="false"/>

    <!-- Aos -->
    <int name="imsemergency.reg_timer_for_ecall_millis_int" value="8000"/>

    <!-- Ut/Xcap AOSP -->
    <int name="gba_mode_int" value="1"/>
    <boolean name="imsss.use_csfb_on_xcap_over_ut_failure_bool" value="false"/>
    <!-- Previous solution was using 8090, but for TLS, requirement is 443 -->
    <int name="imsss.ut_as_server_port_int" value="443"/>
    <int name="imsss.ut_transport_type_int" value="3"/>

    <!-- Ut/Xcap Config -->
    <int-array name="imsss.ut_http_permanent_error_code_int_array" num="0">
    </int-array>

    <!-- Ut/Xcap Assets -->
    <string name="ut_target_address_country_code_replace_to_zero_string">+81</string>

    <!-- MTC -->
    <int name="ims.request_uri_type_int" value="1"/>
    <boolean name="imsvoice.include_caller_id_service_codes_in_sip_invite_bool" value="true"/>
    <boolean name="imsvoice.multiendpoint_supported_bool" value="false"/>
    <boolean name="imsvoice.session_timer_supported_bool" value="true"/>
    <int name="imsvoice.session_expires_timer_sec_int" value="1800"/>
    <int name="imsvoice.session_refresher_type_int" value="0"/>
    <int name="imsvoice.session_privacy_type_int" value="2"/>
    <boolean name="imsvoice.prack_supported_for_18x_bool" value="true"/>
    <int name="imsvoice.conference_subscribe_type_int" value="1"/>
    <boolean name="imsvoice.voice_qos_precondition_supported_bool" value="true"/>
    <boolean name="imsvoice.voice_on_default_bearer_supported_bool" value="true"/>
    <int name="imsvoice.dedicated_bearer_wait_timer_millis_int" value="4000"/>
    <int name="imsvoice.ringing_timer_millis_int" value="60000"/>
    <int name="imsvoice.ringback_timer_millis_int" value="60000"/>
    <int name="imsvoice.session_refresh_method_int" value="1"/>
    <boolean name="imsvoice.oip_source_from_header_bool" value="false"/>
    <int name="imsvoice.mo_call_request_timeout_millis_int" value="0"/>
    <boolean name="imsemergency.retry_emergency_on_ims_pdn_bool" value="false"/>
    <boolean name="imsemergency.emergency_callback_mode_supported_bool" value="true"/>
    <boolean name="imsemergency.emergency_qos_precondition_supported_bool" value="true"/>
    <int name="imsvoice.18x_timer_millis_int" value="10000"/>
    <int name="imsemergency.emergency_ringback_timer_millis_int" value="60000"/>
    <int name="imsemergency.emergency_18x_timer_millis_int" value="10000"/>
    <boolean name="imsvoice.enable_conference_subscribe_by_participant_bool" value="true"/>
    <int name="imsvoice.incoming_call_reject_code_for_user_decline_int" value="603"/>
    <int name="imsvoice.session_refresh_trigger_interval_sec_int" value="1800"/>
    <int name="imsvoice.policy_for_403_response_for_invite_int" value="0"/>
    <int name="imsemergency.emergency_invite_18x_timer_millis_int" value="10000"/>
    <boolean name="imsvoice.enable_oip_header_policy_fallback_bool" value="true"/>
    <boolean name="imsemergency.retry_emergency_call_over_emergency_pdn_with_next_pcscf_bool" value="false"/>
    <int name="imsvoice.policy_for_tcall_timer_expiry_of_volte_call_int" value="0"/>
    <int name="imsemergency.policy_for_tcall_timer_expiry_of_volte_emergency_call_int" value="0"/>
    <int name="imsvoice.eps_fallback_watchdog_time_millis_int" value="0"/>
</carrier_config>
