<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<carrier_config>
    <!-- Ims General -->
    <boolean name="allow_unknown_country_element_for_geolocation_pidf_bool" value="false"/>
    <!-- Aos -->
    <!-- null encryption not supported -->
    <int-array name="ims.ipsec_encryption_algorithms_int_array" num="2">
        <item value="1"/>
        <item value="2"/>
    </int-array>
    <int-array name="ims.ims_identity_priority_int_array" num="2">
        <item value="0"/>
        <item value="2"/>
    </int-array>
    <int name="imswfc.registration_private_header_int" value="2"/>

    <!-- Ut/Xcap AOSP -->
    <boolean name="carrier_supports_ss_over_ut_bool" value="false"/>

    <!-- Ringing timer and Ringback timer -->
    <int name="ringing_timer_millis_int" value="180000"/>
    <int name="ringback_timer_millis_int" value="180000"/>
    <boolean name="imssms.sms_over_ims_supported_bool" value="false"/>

    <!-- MTC default -->
    <int-array name="ims.geolocation_pidf_in_sip_invite_support_int_array" num="2">
        <item value="1"/>
        <item value="2"/>
    </int-array>
    <int-array name="imsvoice.srvcc_type_int_array" num="2">
        <item value="0"/>
        <item value="1"/>
    </int-array>

</carrier_config>
