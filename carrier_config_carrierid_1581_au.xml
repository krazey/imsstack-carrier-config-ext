<carrier_config>
    <!-- Carrier configurations -->
    <!-- Ims General -->
    <boolean name="ims.sip_compact_form_enabled_bool" value="true"/>
    <boolean name="ims.allow_sip_p_access_network_info_header_in_initial_register_bool" value="true"/>

    <int-array name="ims.ipsec_authentication_algorithms_int_array" num="1">
        <item value="1"/>
    </int-array>
    <int-array name="ims.ipsec_encryption_algorithms_int_array" num="1">
        <item value="0"/>
    </int-array>

    <!-- Aos -->
    <boolean name="imsemergency.ereg_set_tcp_only_in_roaming_bool" value="true"/>
    <int name="reg_actual_wait_time_policy_int" value="3"/>
    <int name="reg_retry_cnt_reset_policy_int" value="2"/>
    <int name="rereg_retry_305_policy_int" value="0"/>

    <!-- KEY_EXTRA_REG_ERR_BUNDLE -->
    <pbundle name="ims.extra_reg_err_bundle">
        <boolean name="ims.extra_reg_err_retry_cnt_shared_for_reg_and_sub_bool" value="true"/>
        <int name="ims.extra_reg_err_final_type_int" value="5"/>
        <int name="ims.extra_reg_err_max_cnt_int" value="5"/>
        <int-array name="ims.extra_reg_err_code_int_array" num="2">
            <item value="0"/>
            <item value="2"/>
        </int-array>
        <int-array name="ims.extra_reg_err_code_for_update_int_array" num="8">
            <item value="0"/>
            <item value="305"/>
            <item value="403"/>
            <item value="404"/>
            <item value="408"/>
            <item value="500"/>
            <item value="503"/>
            <item value="504"/>
        </int-array>
    </pbundle>
    <!-- KEY_REG_RETRY_INTERVAL_BUNDLE -->
    <pbundle name="reg_retry_interval_bundle">
        <int-array name="reg_retry_interval_sec_int_array" num="1">
            <item value="10"/>
        </int-array>
    </pbundle>

    <!-- Mtc -->
    <int name="imsvoice.conference_inviting_refer_type_int" value="0"/>
    <int name="imsvoice.conference_subscribe_type_int" value="-1"/>

    <!-- Mts -->
    <int-array name="sms_generic_error_codes_int_array" num="7">
        <item value="0"/>
        <item value="403"/>
        <item value="404"/>
        <item value="408"/>
        <item value="500"/>
        <item value="503"/>
        <item value="504"/>
    </int-array>
    <int name="sms_policy_for_expiry_timer_f_int" value="12"/>
    <int name="sms_policy_for_403_response_int" value="12"/>
    <int name="sms_policy_for_404_response_int" value="12"/>
    <int name="sms_policy_for_408_response_int" value="12"/>
    <int name="sms_policy_for_500_response_int" value="12"/>
    <int name="sms_policy_for_503_response_int" value="12"/>
    <int name="sms_policy_for_504_response_int" value="12"/>
    <int name="sms_retry_after_max_time_sec_int" value="45"/>
    <int name="sms_retry_after_max_count_int" value="5"/>
    <boolean name="sms_report_generic_error_when_retry_after_not_possible_bool" value="true"/>

    <!-- Ut/Xcap AOSP -->
    <int name="gba_mode_int" value="1"/>
    <boolean name="imsss.use_csfb_on_xcap_over_ut_failure_bool" value="false"/>
    <int name="imsss.ut_as_server_port_int" value="8090"/>
    <int name="imsss.ut_transport_type_int" value="1"/>

    <!-- Ut/Xcap Config -->
    <string name="imsss.xcap_auid_prefix_string">/mtasxdms</string>
    <int-array name="imsss.ut_http_permanent_error_code_int_array" num="0">
    </int-array>

    <!-- Ut/Xcap Assets -->
    <boolean name="ut_support_cf_action_erasure_bool" value="false"/>
    <string name="ut_target_address_country_code_replace_to_zero_string">+81</string>
    <int name="ut_xcap_apn_inactivity_timer_sec_int" value="300"/>
</carrier_config>
