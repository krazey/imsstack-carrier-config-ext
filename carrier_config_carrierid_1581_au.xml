<carrier_config>
    <!-- Carrier configurations -->
    <!-- Ims General -->
    <boolean name="ims.sip_compact_form_enabled_bool" value="true"/>
    <boolean name="ims.allow_sip_p_access_network_info_header_in_initial_register_bool" value="true"/>

    <int-array name="ims.ipsec_authentication_algorithms_int_array" num="1">
        <item value="1"/>
    </int-array>
    <int-array name="ims.ipsec_encryption_algorithms_int_array" num="1">
        <item value="0"/>
    </int-array>

    <!-- Aos -->
    <!-- Assets -->
    <int name="registration_actual_wait_time_policy_int" value="3"/>
    <!-- KEY_SPECIFIC_REGISTRATION_ERROR_BUNDLE -->
    <int name="specific_registration_error_final_type_int" value="1"/>
    <int name="specific_registration_error_max_count_int" value="5"/>
    <boolean name="specific_registration_error_retry_count_shared_for_registration_and_reg_event_bool" value="true"/>
    <int-array name="specific_registration_error_code_int_array" num="2">
        <item value="0"/>
        <item value="2"/>
    </int-array>
    <int-array name="specific_reregistration_error_code_int_array" num="8">
        <item value="0"/>
        <item value="305"/>
        <item value="403"/>
        <item value="404"/>
        <item value="408"/>
        <item value="500"/>
        <item value="503"/>
        <item value="504"/>
    </int-array>
    <!-- End BUNDLE -->
    <!-- KEY_REREGISTRATION_RETRY_BUNDLE -->
    <int name="reregistration_retry_sip_305_code_policy_int" value="0"/>
    <!-- End BUNDLE -->
    <!-- KEY_REGISTRATION_RETRY_INTERVAL_BUNDLE -->
    <int-array name="registration_retry_interval_sec_int_array" num="1">
        <item value="10"/>
    </int-array>
    <!-- End BUNDLE -->

    <!-- Ut/Xcap AOSP -->
    <int name="gba_mode_int" value="1"/>
    <boolean name="imsss.use_csfb_on_xcap_over_ut_failure_bool" value="false"/>
    <int name="imsss.ut_as_server_port_int" value="8090"/>
    <int name="imsss.ut_transport_type_int" value="1"/>

    <!-- Ut/Xcap Config -->
    <string name="imsss.xcap_auid_prefix_string">/mtasxdms</string>

    <!-- Ut/Xcap Assets -->
    <boolean name="ut_support_cf_action_erasure_bool" value="false"/>
    <string name="ut_target_address_country_code_replace_to_zero_string">+81</string>
    <int name="ut_xcap_apn_inactivity_timer_sec_int" value="300"/>
</carrier_config>
