<!-- carrier_name: Orange (France) -->
<carrier_config>
    <!-- Please always keep this config on the first line. -->
    <!-- Specifies a list of parent carrier ids from which to inherit configuration values. -->
    <int-array name="ims.parent_carrier_ids_int_array" num="1">
        <item value="900001"/>
    </int-array>

    <!-- Aos -->
    <int name="ims.pdn_reconnect_delay_on_wfc_setup_fail_all_pcscfs_with_cs_roam_sec_int" value="120"/>
    <int name="ims.reg_retry_default_policy_int" value="1"/>
    <int-array name="ims.keep_reg_with_mmtel_feature_tag_policy_int_array" num="1">
        <item value="3"/>
    </int-array>

    <!-- Mtc Assets -->
    <boolean name="imsemergency.emergency_retry_without_checking_380_content_for_non_ue_detectable_emergency_call_bool" value="true"/>
    <string name="imsvoice.content_id_for_geolocation_string">#MSISDN#@#HOME_DOMAIN#</string>

    <!-- Mts -->
    <boolean name="imssms.sms_in_reply_to_validation_bool" value="true"/>

    <!-- Ut/Xcap -->
    <int-array name="imsss.ut_http_permanent_error_code_int_array" num="0">
    </int-array>
    <int-array name="imsss.ut_sm_cause_temporary_block_int_array" num="1">
        <item value="0"/>
    </int-array>
    <int-array name="imsss.ut_http_temporary_error_code_int_array" num="1">
        <item value="403"/>
    </int-array>
    <int name="imsss.ut_temporary_block_timer_min_int" value="240"/>
</carrier_config>
