<carrier_config>
    <!-- Ims General -->
    <boolean name="support_country_param_in_pani_header_bool" value="true"/>

    <!-- Aos -->
    <int name="ims.reg_retry_default_policy_int" value="1"/>
    <int-array name="ims.registration_permanent_error_code_int_array" num="1">
        <item value="403"/>
    </int-array>
    <boolean name="ims.ims_dereg_on_3g_network_bool" value="true"/>
    <boolean name="ims.reg_retry_with_ip_ver_fallback_bool" value="true"/>
    <boolean name="imsemergency.release_emergency_pdn_with_emergency_call_end_bool" value="true"/>

    <!-- MTC -->
    <int name="ims.request_uri_type_int" value="1"/>
    <int-array name="imsvoice.srvcc_type_int_array" num="3">
        <item value="0"/>
        <item value="1"/>
        <item value="3"/>
    </int-array>
    <int name="imsvoice.session_refresh_trigger_interval_sec_int" value="1800"/>
    <int-array name="imsvoice.reject_code_for_csfb_int_array" num="8">
        <item value="403"/>
        <item value="408"/>
        <item value="480"/>
        <item value="488"/>
        <item value="500"/>
        <item value="503"/>
        <item value="600"/>
    </int-array>
    <int name="imsemergency.emergency_ringback_timer_millis_int" value="60000"/>
    <boolean name="imswfc.emergency_call_over_emergency_pdn_bool" value="true"/>
    <boolean name="imsemergency.release_emergency_pdn_with_emergency_call_fail_bool" value="true"/>
    <int name="imswfc.country_code_int" value="1"/>

    <!-- Ut/Xcap AOSP -->
    <int name="gba_mode_int" value="1"/>
    <boolean name="imsss.use_csfb_on_xcap_over_ut_failure_bool" value="true"/>
    <string name="imsss.ut_as_server_fqdn_string">naf.ims.bell.ca</string>
    <int name="imsss.ut_as_server_port_int" value="443"/>
    <int name="imsss.ut_transport_type_int" value="3"/>

    <!-- Ut/Xcap Config -->
    <string name="imsss.xcap_auid_prefix_string">/MyService</string>
</carrier_config>
