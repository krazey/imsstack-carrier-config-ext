    <int-array name="asset_amrnb_codec_attribute_payload_format_int_array" num="1">
        <item value="0"/>
    </int-array>

    <int-array name="asset_amr_amrwb_codec_attribute_modeset_int_array" num="0">
    </int-array>

    <int-array name="asset_amr_amrnb_codec_attribute_modeset_int_array" num="0">
    </int-array>

    <!-- Media common configuration -->
    <int name="audio_maxred_int" value="220"/>
    <int name="asset_codec_attribute_mode_change_capability_int" value="2"/>
    <int name="audio_ptime_millis_int" value="20"/>
    <int name="audio_maxptime_millis_int" value="240"/>
    <boolean name="media_session_level_bandwidth_bool" value="true"/>

    <!--Ut/Xcap Config -->
    <string name="imsss.xcap_auid_prefix_string">/xcap.test.3gpp.com</string>

</carrier_config>
