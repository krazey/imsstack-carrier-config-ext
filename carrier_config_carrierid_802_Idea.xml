<carrier_config>
    <!-- Ims General -->
    <boolean name="allow_unknown_country_element_for_geolocation_pidf_bool" value="false"/>
    <!-- Aos -->
    <int-array name="ims.ims_identity_priority_int_array" num="2">
        <item value="0"/>
        <item value="2"/>
    </int-array>
    <int name="imswfc.registration_private_header_int" value="2"/>

    <!-- Ut/Xcap AOSP -->
    <boolean name="carrier_supports_ss_over_ut_bool" value="true"/>
    <!-- <string name="imsss.ut_as_server_fqdn_string"
                value="xcap.ims.mncXXX.mccYYY.pub.3gppnetwork.org"/> -->
    <!-- Ut supported over LTE only.
      If vowifi registered then device should change mode to LTE for Ut -->
    <int-array name="imsss.xcap_over_ut_supported_rats_int_array" num="1">
        <item value="3"/>
    </int-array>
    <!-- Ut/Xcap Assets -->
    <int name="ut_oir_network_default_operation_int" value="1"/>

    <!-- Media -->
    <boolean name="sdp_reoffer_full_capability_bool" value="true"/>
</carrier_config>
