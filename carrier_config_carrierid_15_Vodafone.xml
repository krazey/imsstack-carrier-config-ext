<carrier_config>
    <!-- Ims General -->
    <boolean name="support_country_param_in_pani_header_bool" value="true"/>

    <!-- Aos -->
    <int-array name="ims.ims_identity_priority_int_array" num="1">
        <item value="1"/>
    </int-array>
    <int-array name="ims.registration_permanent_error_code_int_array" num="1">
        <item value="403"/>
    </int-array>
    <int name="imswfc.registration_private_header_int" value="2"/>
    <int name="reg_retry_cnt_per_pcscf_int" value="3"/>
    <boolean name="ims_dereg_on_3g_network_bool" value="true"/>
    <boolean name="imswfc.use_wfc_country_code_availability_check_bool" value="true"/>

    <!-- Ut/Xcap AOSP -->
    <!-- Previous solution was using 80 and TCP, but VDF AU requirements support both TCP and TLS,
     and TLS is default -->
    <int name="imsss.ut_as_server_port_int" value="443"/>
    <int name="imsss.ut_transport_type_int" value="3"/>
</carrier_config>