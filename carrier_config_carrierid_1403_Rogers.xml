<carrier_config>
    <!-- Ims General -->
    <boolean name="ims.support_country_param_in_pani_header_bool" value="true"/>

    <!-- Aos -->
    <boolean name="ims.hold_reg_with_ipcan_changed_during_ims_call_bool" value="true"/>
    <int-array name="ims.supported_roaming_rats_int_array" num="3">
        <item value="3"/> <!-- CarrierConfig::Ims::ACCESS_NETWORK_TYPE_EUTRAN -->
        <item value="5"/> <!-- CarrierConfig::Ims::ACCESS_NETWORK_TYPE_IWLAN -->
        <item value="6"/> <!-- CarrierConfig::Ims::ACCESS_NETWORK_TYPE_NGRAN -->
    </int-array>
    <int-array name="ims.update_registration_with_rat_change_int_array" num="2">
        <item value="3"/>
        <item value="6"/>
    </int-array>
    <boolean name="imsemergency.reg_timer_for_ecall_timeout_as_failure_bool" value="false"/>
    <int name="imsemergency.reg_timer_for_ecall_millis_int" value="4000"/>
    <boolean name="imswfc.use_wfc_country_code_availability_check_bool" value="true"/>

    <!-- MTC -->
    <boolean name="ims.support_sip_session_id_header_bool" value="true"/>
    <boolean name="imsvoice.enable_send_reinvite_on_rat_change_bool" value="true"/>
    <int name="imswfc.country_code_int" value="1"/>
    <int-array name="imsemergency.policy_for_emergency_urn_int_array" num="1">
        <item value="1"/> <!-- NOT_USE_SERVICE_CATEGORY -->
    </int-array>

    <!-- Media -->
    <boolean name="imsvoice.audio_bw_nego_option_bool" value="false"/>

    <!-- Ut/Xcap -->
    <boolean name="imsss.ut_display_error_phrase_with_409_error_bool" value="true"/>
</carrier_config>
