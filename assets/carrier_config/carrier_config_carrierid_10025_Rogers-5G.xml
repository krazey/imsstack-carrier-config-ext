<carrier_config>
    <!-- Please always keep this config on the first line. -->
    <!-- Specifies a list of parent carrier ids from which to inherit configuration values. -->
    <int-array name="ims.parent_carrier_ids_int_array" num="1">
        <item value="1403"/>
    </int-array>

    <int name="imsvoice.mo_call_request_timeout_for_eps_fallback_trigger_millis_int" value="4000"/>
    <boolean name="imsvoice.enable_send_reinvite_on_rat_change_bool" value="true"/>
    <int-array name="ims.update_registration_with_rat_change_int_array" num="2">
        <item value="3"/>
        <item value="6"/>
    </int-array>
    <int-array name="imsemergency.policy_for_emergency_urn_int_array" num="1">
        <item value="1"/>
    </int-array>
</carrier_config>
